# ============================================================================
# Supply Chain Security Check Tool - .gitignore
# サプライチェーン攻撃防止ツール用 Git除外設定
# ============================================================================

# ============================================================================
# 1. 生成レポートファイル (実行結果)
# ============================================================================
supply_chain_check_report_*.txt
*.log
security_check_*.log
debug.log

# ============================================================================
# 2. 環境変数・認証情報
# ============================================================================
.env
.env.local
.env.*.local
*.key
*.pem
*.p8
secrets.txt
credentials.json
api_keys.json

# ============================================================================
# 3. SSH・GPG鍵
# ============================================================================
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
known_hosts
~/.gnupg/*
!.gnupg/.

# ============================================================================
# 4. OS固有ファイル
# ============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.Icon
Icon?

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.lnk

# Linux
.directory
.Trash-*
*.swp
*.swo

# ============================================================================
# 5. IDE・エディタ設定
# ============================================================================

# VS Code
.vscode/
.vscode/settings.json
.vscode/extensions.json
*.code-workspace

# JetBrains IDEs (IntelliJ, PyCharm, WebStorm等)
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
.vim/
.*.swp
.*.swo
*~

# Emacs
*~
\#*\#
.\#*

# Atom
.atom/

# ============================================================================
