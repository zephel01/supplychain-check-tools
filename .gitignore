# ============================================================================
Gemfile.lock
.bundle/
vendor/bundle/
*.gem

# ============================================================================
# 9. Rust / Cargo
# ============================================================================
target/
Cargo.lock
**/*.rs.bk

# ============================================================================
# 10. Java
# ============================================================================
*.class
*.jar
*.war
target/
.classpath
.project
.settings/

# ============================================================================
# 11. バックアップ・一時ファイル
# ============================================================================
*.backup
*.bak
*.tmp
*.temp
*.orig
*~
*.swp
*.swo
*.swn

# ============================================================================
# 12. 圧縮ファイル
# ============================================================================
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# ============================================================================
# 13. ビルド・キャッシュ
# ============================================================================
build/
dist/
.cache/
*.o
*.a
*.so

# ============================================================================
# 14. ログファイル
# ============================================================================
*.log
*.log.*
logs/
system.log

# ============================================================================
# 15. データベース
# ============================================================================
*.db
*.sqlite
*.sqlite3
*.dbf
.derby/

# ============================================================================
# 16. 機密情報を含むファイル
# ============================================================================
# これらのファイルは絶対にコミットしないこと!
secrets/
private/
confidential/
.secrets
.credentials

# ============================================================================
# 17. テンポラリディレクトリ
# ============================================================================
tmp/
temp/
.tmp/
.temp/

# ============================================================================
# 18. Docker関連
# ============================================================================
.dockerignore
docker-compose.override.yml

# ============================================================================
# 19. Kubernetes
# ============================================================================
k8s/secrets/
*.yaml.bak

# ============================================================================
# 20. その他プロジェクト固有の除外設定
# ============================================================================

# テスト結果
test-results/
test-report/
.test/

# カバレッジ
coverage/
.nyc_output/

# パフォーマンス測定
*.perf
*.profile

# ドキュメント生成物
docs/_build/
docs/inside/
site/

# ============================================================================
# ホワイトリスト (以下は含める)
# ============================================================================
!.gitignore
!.gitattributes
!.github/
!.github/**
!.gitmodules

# ============================================================================
# 注意事項
# ============================================================================
# 
# 【重要】このファイルの推奨修正事項:
#
# 1. 実行結果レポートは絶対にコミットしないこと
#    → supply_chain_check_report_*.txt は除外
#
# 2. 認証情報・キーは絶対にコミットしないこと
#    → .env, *.key, id_rsa等は除外
#
# 3. OS固有の自動生成ファイルは除外
#    → .DS_Store, Thumbs.db等
#
# 4. IDE設定は個人に依存するため除外
#    → .vscode/, .idea/等
#
# 5. 依存パッケージディレクトリは除外
#    → node_modules/, venv/等
#
# 機密情報が誤ってコミットされていないか確認:
# $ git log --all --full-history --source -- <filename>
#
# 誤ってプッシュした場合:
# $ git filter-branch --force --index-filter 'git rm --cached --ignore-unmatch <filename>' HEAD
#
